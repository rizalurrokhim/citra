<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KCA - Stock Gudang</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; padding: 15px; margin: 0; color: #2d3436; padding-bottom: 80px; }
        .header { background: #2d3436; color: white; padding: 15px; border-radius: 12px; display: flex; align-items: center; margin-bottom: 15px; }
        .btn-back { text-decoration: none; background: rgba(255,255,255,0.2); color: white; width: 38px; height: 38px; display: flex; align-items: center; justify-content: center; border-radius: 10px; margin-right: 12px; }
        .card { background: white; padding: 18px; border-radius: 15px; margin-bottom: 15px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
        
        /* Container Item Stok */
        .stock-item { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #f1f3f5; padding: 15px 0; }
        
        /* Area Tombol di Kanan */
        .action-buttons { display: flex; gap: 8px; align-items: center; }

        .badge { padding: 5px 12px; border-radius: 20px; font-size: 11px; font-weight: 700; display: inline-block; margin-top: 5px; }
        .bg-normal { background: #e3f2fd; color: #007bff; }
        .bg-low { background: #fff3cd; color: #856404; }
        .bg-danger { background: #f8d7da; color: #721c24; }

        .search-box { display: flex; gap: 8px; margin-bottom: 15px; }
        #inputCari { flex: 1; padding: 12px; border: 1px solid #dfe6e9; border-radius: 10px; font-size: 16px; }
        .btn-sort { background: #636e72; color: white; border: none; border-radius: 10px; padding: 0 15px; cursor: pointer; }
        
        /* Styling Tombol */
        .btn-primary { background: #007bff; color: white; border: none; padding: 10px 14px; border-radius: 10px; cursor: pointer; font-weight: 600; font-size: 14px; }
        .btn-danger-custom { background: #d63031; color: white; border: none; padding: 10px 14px; border-radius: 10px; cursor: pointer; font-weight: 600; font-size: 14px; }
        .btn-success { background: #28a745; color: white; border: none; padding: 15px; border-radius: 12px; font-weight: bold; width: 100%; cursor: pointer; margin-bottom: 15px; }
        
        .overlay { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.6); z-index:90; }
        .modal { display:none; position:fixed; top:50%; left:50%; transform:translate(-50%,-50%); background:white; padding:25px; border-radius:20px; width:88%; max-width: 420px; z-index:100; max-height: 85vh; overflow-y: auto; }
        .riwayat-btn { position: fixed; bottom: 20px; right: 20px; background: #2d3436; color: white; padding: 15px 25px; border-radius: 30px; border: none; font-weight: bold; z-index: 80; }
        
        select, textarea, .modal input { width: 100%; padding: 12px; margin: 8px 0; border: 1px solid #dfe6e9; border-radius: 10px; box-sizing: border-box; }
    </style>
</head>
<body>

<div class="overlay" id="overlay" onclick="closeModal()"></div>

<div class="header">
    <a href="/" class="btn-back">🏠</a>
    <div>
        <h2 style="margin:0; font-size: 1.1rem;">STOCK GUDANG</h2>
        <small style="opacity: 0.8;">Kios Citra Abadi</small>
    </div>
</div>

<div class="card">
    <button onclick="openAddModal()" class="btn-success">+ Daftar Barang Baru</button>
    
    <div class="search-box">
        <input type="text" id="inputCari" onkeyup="fiturCari()" placeholder="Cari nama barang...">
        <button class="btn-sort" onclick="urutkanAbjad()">A-Z</button>
    </div>

    <div id="listContainer">
        <% stock.forEach(item => { %>
            <div class="stock-item">
                <div style="flex: 1; padding-right: 10px;">
                    <strong class="nama-txt" style="font-size: 15px;"><%= item.nama %></strong><br>
                    <span class="badge <%= item.stock <= 2 ? 'bg-danger' : (item.stock <= 5 ? 'bg-low' : 'bg-normal') %>">
                        <%= item.stock %> <%= item.satuan %>
                    </span>
                </div>
                
                <div class="action-buttons">
                    <button class="btn-primary" onclick="openUpdateModal('<%= item.nama %>')">Update</button>
                    
                    <form action="/stock/hapus" method="POST" onsubmit="return confirm('Hapus <%= item.nama %>?')">
                        <input type="hidden" name="nama" value="<%= item.nama %>">
                        <button type="submit" class="btn-danger-custom">Hapus</button>
                    </form>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<button class="riwayat-btn" onclick="openHistoryModal()">🕒 Riwayat</button>

<div class="modal" id="updateModal">
    <h3>Update Stock</h3>
    <form action="/stock/update" method="POST">
        <input type="hidden" name="nama" id="updateNamaInput">
        <select name="aksi">
            <option value="Masuk">Masuk (Bongkar)</option>
            <option value="Keluar">Keluar (Display)</option>
        </select>
        <input type="number" name="perubahan" placeholder="Jumlah" required>
        <textarea name="keterangan" rows="2" placeholder="Keterangan..."></textarea>
        <button type="submit" class="btn-primary" style="width:100%">Simpan</button>
    </form>
</div>

<div class="modal" id="addModal">
    <h3>Barang Baru</h3>
    <form action="/stock/add-new" method="POST">
        <input type="text" name="nama" placeholder="Nama Barang" required>
        <input type="text" name="satuan" placeholder="Satuan (Karton/Dus)" required>
        <input type="number" name="stock_awal" value="0">
        <button type="submit" class="btn-success">Daftarkan</button>
    </form>
</div>

<div class="modal" id="historyModal">
    <h3>Riwayat Aktivitas</h3>
    <div style="max-height: 400px; overflow-y: auto;">
        <% logs.forEach(log => { %>
            <div style="font-size: 13px; border-left: 4px solid #007bff; padding: 10px; background: #f8f9fa; margin-bottom: 10px;">
                <b><%= log.tanggal %></b><br>
                <%= log.nama %> <b>(<%= log.jumlah %>)</b> - <i><%= log.keterangan %></i>
            </div>
        <% }) %>
    </div>
    <button onclick="closeModal()" class="btn-primary" style="width:100%; margin-top:10px;">Tutup</button>
</div>

<script>
    function fiturCari() {
        let input = document.getElementById("inputCari").value.toLowerCase();
        let items = document.querySelectorAll(".stock-item");
        items.forEach(it => {
            let txt = it.querySelector(".nama-txt").innerText.toLowerCase();
            it.style.display = txt.includes(input) ? "flex" : "none";
        });
    }
    function urutkanAbjad() {
        let container = document.getElementById("listContainer");
        let items = Array.from(container.getElementsByClassName("stock-item"));
        items.sort((a, b) => a.querySelector(".nama-txt").innerText.localeCompare(b.querySelector(".nama-txt").innerText));
        items.forEach(it => container.appendChild(it));
    }
    function openUpdateModal(n) {
        document.getElementById('updateNamaInput').value = n;
        document.getElementById('updateModal').style.display = 'block';
        document.getElementById('overlay').style.display = 'block';
    }
    function openAddModal() {
        document.getElementById('addModal').style.display = 'block';
        document.getElementById('overlay').style.display = 'block';
    }
    function openHistoryModal() {
        document.getElementById('historyModal').style.display = 'block';
        document.getElementById('overlay').style.display = 'block';
    }
    function closeModal() {
        document.querySelectorAll('.modal').forEach(m => m.style.display = 'none');
        document.getElementById('overlay').style.display = 'none';
    }
</script>
</body>
</html>
